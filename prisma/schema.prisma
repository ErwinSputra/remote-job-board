// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum SubscriptionPlan {
  FREE
  PREMIUM_POSTER
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

enum JobStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CLOSED
}

// --- MODELS ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role?      

  companies     Company[]
  subscription  Subscription?
  savedJobs     SavedJob[]    

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  coverUrl    String?  // Banner/cover image for company profile page
  website     String?
  description String?  @db.Text
  size        String?  // e.g. "1-10", "11-50", "51-200", "200+"
  industry    String?  // e.g. "Technology", "Finance"
  location    String?  // HQ location e.g. "Jakarta, Indonesia"
  twitter     String?  // Social links
  linkedin    String?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobs        Job[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String          @db.Text
  requirements    String?         @db.Text  // Separate requirements section
  benefits        String?         @db.Text  // Perks & benefits
  type            JobType
  status          JobStatus       @default(ACTIVE)  // Draft/Active/Expired/Closed
  category        String
  tags            String[]        // e.g. ["React", "TypeScript", "Node.js"]
  experienceLevel ExperienceLevel @default(MID)  // Seniority filter
  region          String?

  salaryMin       Int?
  salaryMax       Int?
  currency        String          @default("USD")
  salaryPublic    Boolean         @default(true)  // Option to hide salary

  isFeatured      Boolean         @default(false)
  featuredUntil   DateTime?
  expiresAt       DateTime?       // Auto-expire job listings

  companyId       String
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  savedBy         SavedJob[]      // Reverse relation for bookmarks

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category, type])
  @@index([status, isFeatured])   // For homepage featured query
  @@index([expiresAt])            // For cleanup/expiry jobs
}

// Bookmark/saved jobs feature for candidates
model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])  // Prevent duplicate saves
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)

  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}