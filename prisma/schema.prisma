// prisma/schema.prisma

// -----------------------------------------------------------------------------
// PRISMA CLIENT & DATABASE CONFIGURATION
// -----------------------------------------------------------------------------
// Configures the Prisma Client generator and connects to the PostgreSQL database.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS (PREDEFINED DATA TYPES)
// -----------------------------------------------------------------------------
// Enforces strict data types to maintain database integrity across the application.

// Defines user access levels for role-based routing (Candidate, Employer, or Admin).
enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

// Maps to Stripe subscription plans to manage job posting capabilities/limits.
enum SubscriptionPlan {
  FREE
  PREMIUM_POSTER
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

// Controls the visibility of job postings on the platform.
enum JobStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CLOSED
}

// -----------------------------------------------------------------------------
// DATABASE MODELS
// -----------------------------------------------------------------------------

// CORE USER MODEL
// Extended NextAuth User model. Handles authentication and serves as the central
// hub tying a user to their specific role, companies (Employers), subscriptions,
// and saved jobs (Candidates).
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role?      

  // Relations
  companies     Company[]
  subscription  Subscription?
  savedJobs     SavedJob[]    

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// COMPANY MODEL
// Represents an Employer's organization. A user (Employer) can manage multiple
// companies. Tied to jobs via a one-to-many relationship.
model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  coverUrl    String?  // Banner/cover image for the company profile page
  website     String?
  description String?  @db.Text
  size        String?  // e.g. "1-10", "11-50", "51-200", "200+"
  industry    String?  // e.g. "Technology", "Finance"
  location    String?  // HQ location e.g. "Jakarta, Indonesia"
  twitter     String?  // Social links
  linkedin    String?

  // Relation to Employer (User). Cascade delete ensures companies are cleanly removed if the user is deleted.
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobs        Job[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// JOB POSTING MODEL
// Contains all details for a specific job. Includes essential database indexing 
// for faster homepage querying, filtering, and automated expiration sweeps.
model Job {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String          @db.Text
  requirements    String?         @db.Text  // Separate requirements section
  benefits        String?         @db.Text  // Perks & benefits
  type            JobType
  status          JobStatus       @default(ACTIVE)  // Draft/Active/Expired/Closed
  category        String
  tags            String[]        // e.g. ["React", "TypeScript", "Node.js"]
  experienceLevel ExperienceLevel @default(MID)  // Seniority filter
  region          String?

  // Compensation details
  salaryMin       Int?
  salaryMax       Int?
  currency        String          @default("USD")
  salaryPublic    Boolean         @default(true)  // Option to hide salary

  // Premium & visibility features
  isFeatured      Boolean         @default(false)
  featuredUntil   DateTime?
  expiresAt       DateTime?       // Auto-expire job listings

  // Relations
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  savedBy         SavedJob[]      // Reverse relation for candidate bookmarks

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Optimized Database Indexes for high-performance querying
  @@index([category, type])
  @@index([status, isFeatured])   // Crucial for homepage 'Featured' section queries
  @@index([expiresAt])            // Optimizes background cron jobs or cleanup tasks
}

// SAVED JOBS (BOOKMARKS) MODEL
// Acts as a junction table between User (Candidate) and Job. Allows candidates
// to bookmark jobs for later viewing.
model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  
  // Cascade delete ensures bookmarks are removed if the Job or User no longer exists.
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  // Prevents a candidate from saving the exact same job multiple times.
  @@unique([userId, jobId])  
}

// SUBSCRIPTION MODEL
// Handles Stripe billing information for Employers. Synced via Stripe Webhooks
// to grant 'PREMIUM_POSTER' privileges seamlessly.
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)

  // Stripe mapping IDs (Populated & automatically updated via Webhooks)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}